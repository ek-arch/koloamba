# Copy to .env.local and fill in values. Never commit .env.local.

# Supabase — https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=            # generate: openssl rand -base64 32
AUTH_SECRET=                # same value as NEXTAUTH_SECRET (NextAuth v5)

# Twitter / X OAuth 2.0 — https://developer.x.com/en/portal/dashboard
# Callback URL: http://localhost:3000/api/auth/callback/twitter
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# TwitterScore API — https://twitterscore.io
TWITTER_SCORE_API_KEY=
TWITTER_SCORE_API_URL=https://api.twitterscore.io

# Campaign defaults
DEFAULT_POOL_AMOUNT=1000
